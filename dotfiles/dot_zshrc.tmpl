# ── Environment ────────────────────────────────────────────────
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_STATE_HOME="$HOME/.local/state"

export PATH="$HOME/.local/bin:$PATH"
export EDITOR="nvim"
export TERM="xterm-256color"

export BAT_THEME="Catppuccin Macchiato"
export RIPGREP_CONFIG_PATH="$HOME/.config/ripgrep/config"

# ── mise ───────────────────────────────────────────────────────
if [[ ! -x "$HOME/.local/bin/mise" ]]; then
  curl https://mise.run | sh
  "$HOME/.local/bin/mise" install
  # Bat catppuccin theme
  mkdir -p "$HOME/.config/bat/themes"
  curl -sL "https://github.com/catppuccin/bat/raw/main/themes/Catppuccin%20Macchiato.tmTheme" \
    -o "$HOME/.config/bat/themes/Catppuccin Macchiato.tmTheme"
  "$HOME/.local/bin/mise" exec -- bat cache --build 2>/dev/null || true
fi
eval "$($HOME/.local/bin/mise activate zsh)"

# ── zinit ──────────────────────────────────────────────────────
ZINIT_HOME="${XDG_DATA_HOME}/zinit/zinit.git"
if [[ ! -d "$ZINIT_HOME" ]]; then
  mkdir -p "$(dirname "$ZINIT_HOME")"
  git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
fi
source "${ZINIT_HOME}/zinit.zsh"

ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=#8087a2"  # overlay1

zinit wait lucid light-mode for \
  zsh-users/zsh-autosuggestions \
  zdharma-continuum/fast-syntax-highlighting \
  zsh-users/zsh-completions \
  Aloxaf/fzf-tab

# ── Prompt & tools ─────────────────────────────────────────────
eval "$(starship init zsh)"
eval "$(zoxide init zsh --cmd cd)"
eval "$(fzf --zsh)"

# ── Vi mode ────────────────────────────────────────────────────
bindkey -v
export KEYTIMEOUT=1

# History search on arrow keys (works in both insert and normal mode)
bindkey '^[[A'    history-search-backward
bindkey '^[[B'    history-search-forward
bindkey '\e[A'    history-search-backward
bindkey '\e[B'    history-search-forward
bindkey -M vicmd 'k' history-search-backward
bindkey -M vicmd 'j' history-search-forward

# Word navigation
bindkey '^[[1;5C' forward-word   # Ctrl+Right
bindkey '^[[1;5D' backward-word  # Ctrl+Left

# ── History ────────────────────────────────────────────────────
HISTFILE="${XDG_STATE_HOME}/zsh/history"
HISTSIZE=1000000
SAVEHIST=1000000
[[ ! -d "$(dirname "$HISTFILE")" ]] && mkdir -p "$(dirname "$HISTFILE")"
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_SAVE_NO_DUPS
setopt HIST_FIND_NO_DUPS
setopt HIST_IGNORE_SPACE
setopt SHARE_HISTORY
setopt EXTENDED_HISTORY
setopt HIST_VERIFY

# ── Shell options ──────────────────────────────────────────────
setopt AUTO_CD
setopt COMPLETE_IN_WORD
setopt NO_BEEP

# ── Completion ─────────────────────────────────────────────────
autoload -Uz compinit _zinit
[[ ! -d "${XDG_CACHE_HOME}/zsh" ]] && mkdir -p "${XDG_CACHE_HOME}/zsh"
_zcompdump="${XDG_CACHE_HOME}/zsh/zcompdump-${ZSH_VERSION}"
if [[ -n ${_zcompdump}(#qN.mh+24) ]]; then
  compinit -d "$_zcompdump"
else
  compinit -C -d "$_zcompdump"
fi
unset _zcompdump
zinit cdreplay -q
(( ${+_comps} )) && _comps[zinit]=_zinit

zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*:descriptions' format '[%d]'

# fzf-tab previews
zstyle ':fzf-tab:complete:cd:*'          fzf-preview 'eza --tree --icons --color=always $realpath 2>/dev/null | head -50'
zstyle ':fzf-tab:complete:__zoxide_z:*'  fzf-preview 'eza --tree --icons --color=always $realpath 2>/dev/null | head -50'
zstyle ':fzf-tab:complete:*'             fzf-preview 'bat --color=always $realpath 2>/dev/null | head -50'
zstyle ':fzf-tab:*'              switch-group ',' '.'

# ── fzf ────────────────────────────────────────────────────────
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_DEFAULT_OPTS='--height 40% --layout=reverse --border --inline-info'
export FZF_DEFAULT_OPTS+=' --color=bg+:#363a4f,bg:#24273a,spinner:#f4dbd6,hl:#ed8796'
export FZF_DEFAULT_OPTS+=' --color=fg:#cad3f5,header:#ed8796,info:#c6a0f6,pointer:#f4dbd6'
export FZF_DEFAULT_OPTS+=' --color=marker:#b7bdf8,fg+:#cad3f5,prompt:#c6a0f6,hl+:#ed8796'
export FZF_DEFAULT_OPTS+=' --color=selected-bg:#494d64'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_CTRL_T_OPTS="--preview 'bat --color=always {} 2>/dev/null | head -50'"
export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
export FZF_ALT_C_OPTS="--preview 'eza --tree --icons --color=always {} 2>/dev/null | head -50'"

# ── Aliases — navigation ───────────────────────────────────────
alias ..='cd ..'
alias ...='cd ../..'

# ── Aliases — tools ────────────────────────────────────────────
alias ls='eza --icons'
alias ll='eza -lah --icons --git'
alias lt='eza --tree --icons'
alias cat='bat --paging=never'
alias grep='rg'
alias find='fd'
alias vim='nvim'
alias vi='nvim'
alias lg='lazygit'
alias c='clear'
alias python='python3'

# ── Aliases — terraform ────────────────────────────────────────
alias tf='terraform'
alias tfi='terraform init'
alias tfp='terraform plan'
alias tfa='terraform apply'

# ── Aliases — ansible ──────────────────────────────────────────
alias ap='ansible-playbook'
alias apv='ansible-playbook --ask-vault-pass'

# ── Functions ──────────────────────────────────────────────────
# Pin all active mise tools to their current versions globally
mise_pin() {
  mise ls --current | awk '{print $1"@"$2}' | xargs mise use --global
}

# Update mise binary and all managed tools
mise_update() {
  mise self-update
  mise upgrade
}

# Refresh font cache
update_fonts() {
  fc-cache -fv
}

# ── Greeting (interactive shells only) ─────────────────────────
if [[ $- == *i* ]]; then
  fastfetch
fi

# ── Local overrides ────────────────────────────────────────────
[[ -f "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"
